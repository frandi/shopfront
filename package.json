{
  "name": "shopfront",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm --filter @shopfront/shared run build && pnpm --filter \"./apps/*\" run build",
    "dev": "pnpm --parallel --filter \"./apps/*\" run dev",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
